INTERNAL_API_SHARED_SECRET=change-me

# Backend
BACKEND_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/consentos
BACKEND_FRONTEND_URL=http://localhost:3000
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
BACKEND_CONNECTED_ACCOUNTS_STALE_AFTER_MINUTES=1440
# /health/ready will stay degraded until the relevant Auth0 values below are configured for your target flow.
BACKEND_AUTH0_DOMAIN=your-tenant.us.auth0.com
BACKEND_AUTH0_AUDIENCE=https://api.consientos.local
BACKEND_AUTH0_ISSUER=https://your-tenant.us.auth0.com/
BACKEND_AUTH0_CLIENT_ID=
BACKEND_AUTH0_CLIENT_SECRET=
BACKEND_AUTH0_CIBA_CLIENT_ID=
BACKEND_AUTH0_CIBA_CLIENT_SECRET=
BACKEND_AUTH0_CONNECTED_ACCOUNTS_SCOPE=read:me:connected_accounts create:me:connected_accounts
BACKEND_ALLOW_DEV_AUTH_HEADERS=false
BACKEND_ALLOW_MOCK_CONNECTED_ACCOUNTS=false
BACKEND_ALLOW_MOCK_TOKEN_VAULT=false
BACKEND_AUTO_APPROVE_WHEN_CIBA_UNAVAILABLE=false
BACKEND_AUTO_APPROVE_DELAY_SECONDS=2

# MCP / orchestrator
MCP_BACKEND_BASE_URL=http://localhost:8000
MCP_GEMINI_API_KEY=
MCP_GEMINI_MODEL=gemini-2.0-flash
MCP_APPROVAL_TIMEOUT_SECONDS=120
MCP_GMAIL_RECENT_QUERY=newer_than:90d (invoice OR payment OR overdue OR "past due")
MCP_GMAIL_RECENT_LIMIT=50
MCP_CALENDAR_ID=primary
MCP_CALENDAR_LOOKAHEAD_DAYS=30
MCP_CALENDAR_RECENT_LIMIT=10
MCP_STRIPE_RECENT_LIMIT=10
MCP_STRIPE_DEFAULT_CURRENCY=usd
MCP_SLACK_RECENT_LIMIT=25
MCP_SLACK_MENTION_CHANNEL_IDS=["C0123456789"]
MCP_SLACK_MENTION_KEYWORDS=["invoice","payment","paid","overdue","follow up","follow-up"]

# Frontend
NEXT_PUBLIC_APP_NAME=ConsentOS
NEXT_PUBLIC_DEFAULT_AGENT=FreelanceCOOAgent

# Required frontend Auth0 browser-session configuration
AUTH0_SECRET=replace-with-32-byte-random
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SCOPE=openid profile email offline_access
APP_BASE_URL=http://localhost:3000

# Optional frontend Auth0/API proxy settings
AUTH0_AUDIENCE=https://api.consentos.local
BACKEND_PROXY_URL=http://localhost:8000
ORCHESTRATOR_BASE_URL=http://localhost:8100
